# Star Wars GraphDB Configuration

# OpenAI API Key (optional)
OPENAI_API_KEY=your-api-key-here

# Moonshotai/Kimi API Key (optional)
MOONSHOTAI_API_KEY=your-moonshotai-key-here

# Model to use for AI agent
# Options: gpt-4, gpt-3.5-turbo (OpenAI)
#          kimi-k2.5 (Moonshotai)
# Default: gpt-4 (or kimi-k2.5 if Moonshotai key is provided)
SWAPI_MODEL=kimi-k2.5

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
